# TerminalX Configuration
# Copy to .env and customize as needed

# Server
PORT=3000
TERMINUS_HOST=0.0.0.0

# File browser root directory (default: $HOME)
TERMINUS_ROOT=/home/user

# Default shell for terminal sessions
TERMINUS_SHELL=/bin/bash

# Maximum concurrent terminal sessions
TERMINUS_MAX_SESSIONS=20

# Terminal scrollback buffer size (lines)
TERMINUS_SCROLLBACK=10000

# Read-only mode: disables terminal access, file uploads, and session management
TERMINUS_READ_ONLY=false

# Log directories to scan (comma-separated)
TERMINUS_LOG_PATHS=/var/log,~/.pm2/logs

# Auth mode: "none" (no auth), "password" (shared password), "local" (user accounts), "google" (Google OAuth)
TERMINALX_AUTH_MODE=none

# Required when TERMINALX_AUTH_MODE=password
# TERMINALX_PASSWORD=your-shared-password

# Required when TERMINALX_AUTH_MODE=local (created on first startup if no users exist)
# TERMINALX_ADMIN_USERNAME=admin
# TERMINALX_ADMIN_PASSWORD=your-admin-password

# Required when TERMINALX_AUTH_MODE=google
# TERMINALX_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# TERMINALX_GOOGLE_CLIENT_SECRET=your-google-client-secret
# TERMINALX_GOOGLE_CALLBACK_URL=/api/auth/google/callback
# TERMINALX_ALLOWED_EMAILS=user1@gmail.com,user2@gmail.com

# JWT secret (auto-generated if not set)
# TERMINALX_JWT_SECRET=your-secret-at-least-32-chars

# ── Telegram bot (optional) ────────────────────────────────────────────────
# Lets you attach to tmux sessions from Telegram with the same surface area
# as the web app. Disabled when TERMINALX_TELEGRAM_BOT_TOKEN is unset.
#
# Setup:
#   1. Talk to @BotFather, /newbot, copy the token.
#   2. Add the bot to a Telegram supergroup, promote it to admin with
#      "Manage Topics" permission, enable Topics on the group.
#   3. Find the (negative) chat id of that group → TERMINALX_TELEGRAM_FORUM_CHAT_ID.
#   4. Find your Telegram user id → TERMINALX_TELEGRAM_ALLOWED_USERS.
#   5. Pick a long random string for the webhook secret. The bot calls
#      setWebhook at startup; Telegram POSTs updates to the URL below
#      with that secret in the X-Telegram-Bot-Api-Secret-Token header.
#
# TERMINALX_TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# TERMINALX_TELEGRAM_WEBHOOK_URL=https://your.host/api/telegram/webhook
# TERMINALX_TELEGRAM_WEBHOOK_SECRET=long-random-string-32+chars
# TERMINALX_TELEGRAM_ALLOWED_USERS=123456789:admin
# TERMINALX_TELEGRAM_FORUM_CHAT_ID=-1001234567890
# TERMINALX_TELEGRAM_MAX_TOPICS=10
# TERMINALX_TELEGRAM_DEBUG=1   # logs every incoming update; off by default
